<section class="comments-section">
  <h2>Comments</h2>

  <!-- Post a comment form -->
  <form action="/events/<%= eventId %>/comments" method="POST">
    <textarea
      name="text"
      placeholder="Write a comment..."
      maxlength="500"
      required
    ></textarea>
    <button type="submit">Post Comment</button>
  </form>

  <!-- Comments list -->
  <% if (comments.length === 0) { %>
    <p>No comments yet. Be the first to comment!</p>
  <% } else { %>
    <% comments.forEach(function(comment) { %>
      <div class="comment">
        <p><strong><%= comment.userId %></strong></p>
        <p><%= comment.text %></p>
        <p><small><%= comment.createdAt %></small></p>

        <% if (currentUserId === comment.userId || userRole === 'admin' || userRole === 'organizer') { %>
          <form action="/comments/<%= comment.id %>?_method=DELETE" method="POST">
            <button type="submit">Delete</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</section>